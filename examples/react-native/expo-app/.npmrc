# Metro cannot resolve packages from pnpm's symlinked .pnpm store, so use a
# flat node_modules layout (same approach as examples/react-native/app at the
# repo root, which relies on public-hoist-pattern in the root .npmrc).
node-linker=hoisted

# Hoist packages Metro, Expo CLI, and Gradle scripts resolve from the project root.
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@amplitude/*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=@react-native-community/*
public-hoist-pattern[]=@react-navigation/*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=metro
public-hoist-pattern[]=metro-*
