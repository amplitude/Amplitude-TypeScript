# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'example' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Explicitly include the standalone session-replay-react-native native module
  # so its iOS files (NativeSessionReplay.swift, AMPNativeSessionReplay.mm)
  # are compiled as part of the example app build.
  pod 'AmplitudeSessionReplayReactNative', :path => '../../../session-replay-react-native'

  target 'exampleTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    # Fix for Xcode 26: dropped swiftCompatibility56 shim. Bump all pods to iOS 16
    # to eliminate the Swift 5.6 backward-compat shim dependency, and add Swift
    # library search paths so the linker can resolve _swiftCompatibility56.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['SWIFT_VERSION'] = '5.0'
        # Swift lib search path needed for Xcode 26+
        swift_lib_dir = '$(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)'
        existing = config.build_settings['LIBRARY_SEARCH_PATHS'] || ['$(inherited)']
        existing = [existing] if existing.is_a?(String)
        unless existing.include?(swift_lib_dir)
          config.build_settings['LIBRARY_SEARCH_PATHS'] = existing + [swift_lib_dir]
        end
      end
    end
  end
end
